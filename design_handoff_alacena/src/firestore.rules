rules_version = '2';

// ============================================================================
// REGLAS DE FIRESTORE — ALPHA FAMILIAR
// ----------------------------------------------------------------------------
// ⚠️ DESARROLLO: acceso totalmente abierto. NO usar en producción.
// La alpha no tiene autenticación; los datos son compartidos por la familia.
// Antes de exponer la app públicamente, restringe el acceso (p.ej. con
// Firebase Auth o una fecha de caducidad).
// ============================================================================
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
